{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 1
      },
      "content": [
        {
          "type": "text",
          "text": "اتفاقية عدم إفصاح متبادلة"
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 1
      },
      "content": [
        {
          "type": "text",
          "text": "Mutual Non-Disclosure Agreement"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "أبرمت هذه الاتفاقية بتاريخ 17 يونيو 2026 بين:"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "الطرف الأول: شركة الأردن للتوريدات، شركة مساهمة خاصة مسجلة في المملكة الأردنية الهاشمية (\"الطرف المفصح\")"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "الطرف الثاني: شركة Acme MENA Holdings Ltd، شركة محدودة مسجلة في مركز دبي المالي العالمي (\"الطرف المتلقي\")"
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "1. تعريفات"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "\"المعلومات السرية\" تعني أي معلومات تقنية أو تجارية أو مالية يفصح عنها أحد الطرفين للآخر، سواء كانت مكتوبة أو شفهية أو إلكترونية."
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "2. Obligations of the Receiving Party"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "The Receiving Party shall hold all Confidential Information in strict confidence and shall not disclose such information to any third party without the prior written consent of the Disclosing Party."
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "3. الاستثناءات"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "لا تشمل المعلومات السرية أي معلومات: (أ) كانت متاحة للعموم وقت الإفصاح، أو (ب) أصبحت متاحة للعموم دون خطأ من الطرف المتلقي."
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "4. المدة والإنهاء"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "تسري هذه الاتفاقية لمدة سنتين (2) من تاريخ التوقيع، وتتجدد تلقائياً لفترات مماثلة ما لم يخطر أحد الطرفين الآخر كتابياً قبل 30 يوماً من انتهاء المدة."
        }
      ]
    },
    {
      "type": "heading",
      "attrs": {
        "textAlign": null,
        "level": 2
      },
      "content": [
        {
          "type": "text",
          "text": "5. Governing Law"
        }
      ]
    },
    {
      "type": "paragraph",
      "attrs": {
        "textAlign": null
      },
      "content": [
        {
          "type": "text",
          "text": "This Agreement shall be governed by and construed in accordance with the laws of the Hashemite Kingdom of Jordan. Any dispute arising hereunder shall be referred to the competent courts of Amman."
        }
      ]
    },
